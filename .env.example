# Environment variables template
# All settings use GHOS_ prefix — see IdentitySettings for all options.

# Database (PostgreSQL)
GHOS_DATABASE_URL=postgresql+asyncpg://ghos:ghos@localhost:5432/ghos_identity

# JWT — Generate RSA keys for production:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
GHOS_JWT_PRIVATE_KEY=
GHOS_JWT_PUBLIC_KEY=
GHOS_JWT_SECRET=ghos-identity-jwt-secret-change-in-production
GHOS_JWT_ALGORITHM=RS256

# Redis
GHOS_REDIS_URL=redis://localhost:6379/0

# bcrypt cost (>= 12 recommended)
GHOS_BCRYPT_ROUNDS=12
